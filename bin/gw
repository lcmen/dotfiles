#!/usr/bin/env bash

# Manage git worktrees with automatic file copying and dependency installation.
#
# Usage: gw <add|remove> <branch> [name]

set -euo pipefail

usage() {
  echo "Usage: gw <add|remove> <branch> [name]"
  exit 1
}

[[ $# -lt 2 || $# -gt 3 ]] && usage

command="$1"
branch="$2"
name="${3:-$branch}"
current_dir="$(basename "$(pwd)")"
worktree_path="../${current_dir}-${name}"

COPY_FILES=(
  .bundle
  .claude
  .env.local
  .env.development.local
  .env.test.local
  .projections.json
  config/credentials
  config/master.key
  Procfile.dev.local
  tmp/local_secret.txt
)

SKIP_HOOKS_ENV=(
  HUSKY=0
  LEFTHOOK=0
  OVERCOMMIT_DISABLE=1
)

add_worktree() {
  # Check if branch exists locally or on remote
  local local_ref="refs/heads/$branch"
  local remote_ref="refs/remotes/origin/$branch"
  if git show-ref --verify --quiet "$local_ref" || git show-ref --verify --quiet "$remote_ref"; then
    env "${SKIP_HOOKS_ENV[@]}" git worktree add "$worktree_path" "$branch"
  else
    env "${SKIP_HOOKS_ENV[@]}" git worktree add -b "$branch" "$worktree_path"
  fi
  cd "$worktree_path"
  mise trust --all
}

remove_worktree() {
  worktree_path=$(git worktree list | grep "\[${branch}\]" | awk '{print $1}')
  if [[ -z "$worktree_path" ]]; then
    echo "No worktree found for branch '$branch'"
    exit 1
  fi
  git worktree remove "$worktree_path"
  git branch -D "$branch"
}

copy_files() {
  for file in "${COPY_FILES[@]}"; do
    local src="../${current_dir}/${file}"
    if [[ -e "$src" ]]; then
      mkdir -p "$(dirname "$file")"
      cp -r "$src" "$file"
    fi
  done
}

install_deps() {
  mise install

  if [[ -f Gemfile ]]; then
    bundle install
  fi

  if [[ -f mix.exs ]]; then
    mix deps.get
  fi

  if [[ -f go.mod ]]; then
    go mod download
  fi

  if [[ -f package-lock.json ]]; then
    npm install
  fi

  if [[ -f yarn.lock ]]; then
    yarn install
  fi
}

build_tab_cmd() {
  local dir="$1"
  local session_name="$2"

  if command -v tmux &>/dev/null; then
    if tmux has-session -t "$session_name" 2>/dev/null; then
      echo "cd '$dir' && tmux attach -t '$session_name'"
    else
      echo "cd '$dir' && tmux new-session -s '$session_name'"
    fi
  else
    echo "cd '$dir'"
  fi
}

open_in_windows_terminal() {
  local dir="$1"
  local session_name="$2"
  local tab_cmd="$3"
  local win_dir
  win_dir="$(wslpath -w "$dir")"

  if command -v tmux &>/dev/null; then
    wt.exe -w 0 new-tab --profile "$WSL_DISTRO_NAME" --title "$session_name" -d "$win_dir" -- bash -ic "$tab_cmd"
  else
    wt.exe -w 0 new-tab --profile "$WSL_DISTRO_NAME" --title "$session_name" -d "$win_dir"
  fi
}

open_in_iterm() {
  local session_name="$1"
  local tab_cmd="$2"

  osascript <<EOF || echo "Could not open iTerm2 tab."
tell application "iTerm2"
  tell current window
    create tab with default profile
    tell current session
      set name to "$session_name"
      write text "$tab_cmd"
    end tell
  end tell
end tell
EOF
}

open_in_apple_terminal() {
  local session_name="$1"
  local tab_cmd="$2"

  osascript <<EOF || echo "Could not open Terminal.app tab."
tell application "Terminal"
  activate
  tell application "System Events" to keystroke "t" using command down
  do script "$tab_cmd" in front window
  set custom title of front tab of front window to "$session_name"
end tell
EOF
}

open_worktree() {
  local dir="$1"
  local session_name="$2"

  # Sanitize for tmux (no dots or colons)
  session_name="${session_name//[:.]/-}"

  local tab_cmd
  tab_cmd="$(build_tab_cmd "$dir" "$session_name")"

  # WSL + Windows Terminal
  if [[ -n "${WSL_DISTRO_NAME:-}" ]] && command -v wt.exe &>/dev/null; then
    open_in_windows_terminal "$dir" "$session_name" "$tab_cmd"
    return
  fi

  # iTerm2
  if [[ "${TERM_PROGRAM:-}" == "iTerm.app" ]]; then
    open_in_iterm "$session_name" "$tab_cmd"
    return
  fi

  # macOS Terminal.app
  if [[ "${TERM_PROGRAM:-}" == "Apple_Terminal" ]]; then
    open_in_apple_terminal "$session_name" "$tab_cmd"
    return
  fi

  # Fallback: no supported terminal — create detached tmux or print path
  if command -v tmux &>/dev/null; then
    if tmux has-session -t "$session_name" 2>/dev/null; then
      echo "tmux session '$session_name' already exists. Attach with: tmux attach -t $session_name"
    else
      tmux new-session -d -s "$session_name" -c "$dir"
      echo "tmux session '$session_name' created. Attach with: tmux attach -t $session_name"
    fi
  else
    echo "Worktree ready at: $dir"
  fi
}

case "$command" in
add)
  add_worktree
  copy_files
  install_deps
  open_worktree "$(pwd)" "$name"
  ;;
remove)
  remove_worktree
  ;;
*)
  usage
  ;;
esac
