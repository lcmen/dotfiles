#!/usr/bin/env bash

# Manage git worktrees with automatic file copying and dependency installation.
#
# Usage: gw add [branch]
#        gw remove <name>

set -euo pipefail

COPY_FILES=(
  .bundle
  .claude
  .env.local
  .env.development.local
  .env.test.local
  .insights
  .projections.json
  config/credentials
  config/master.key
  Procfile.dev.local
  tmp/local_secret.txt
)

DIRECTORY="$(basename "$(pwd)")"

NAME_POOL=(amber bronze cedar coral crimson dune elm fern gold hazel indigo ivory jade lemon lilac maple nova opal peach quartz ruby sage teal umber violet willow zinc)

SKIP_HOOKS_ENV=(
  HUSKY=0
  LEFTHOOK=0
  OVERCOMMIT_DISABLE=1
)

add_worktree() {
  local branch="$1"
  local path="$2"
  # Check if branch exists locally or on remote
  local local_ref="refs/heads/$branch"
  local remote_ref="refs/remotes/origin/$branch"
  if git show-ref --verify --quiet "$local_ref" || git show-ref --verify --quiet "$remote_ref"; then
    env "${SKIP_HOOKS_ENV[@]}" git worktree add "$path" "$branch"
  else
    env "${SKIP_HOOKS_ENV[@]}" git worktree add -b "$branch" "$path"
  fi
  cd "$path"
  mise trust --all
}

remove_worktree() {
  local path="$1"
  shift
  if [[ ! -d "$path" ]]; then
    echo "No worktree found at '$path'"
    exit 1
  fi
  local wt_branch
  wt_branch=$(git -C "$path" rev-parse --abbrev-ref HEAD)
  git worktree remove "$@" "$path"
  git branch -D "$wt_branch"
}

copy_files() {
  for file in "${COPY_FILES[@]}"; do
    local src="../${DIRECTORY}/${file}"
    # If directory exists, merge its contents
    if [[ -d "$src" ]]; then
      mkdir -p "$file"
      cp -r "$src/." "$file/"
    # If file does not exist, copy it (and crete directories if missing)
    elif [[ -e "$src" ]]; then
      mkdir -p "$(dirname "$file")"
      cp -r "$src" "$file"
    fi
  done
}

build_tab_cmd() {
  local dir="$1"
  local session_name="$2"

  # Install deps
  local deps="mise install"
  if [[ -f "$dir/Gemfile" ]]; then deps="$deps && bundle install"; fi
  if [[ -f "$dir/mix.exs" ]]; then deps="$deps && mix deps.get"; fi
  if [[ -f "$dir/go.mod" ]]; then deps="$deps && go mod download"; fi
  if [[ -f "$dir/package-lock.json" ]]; then deps="$deps && npm install"; fi
  if [[ -f "$dir/yarn.lock" ]]; then deps="$deps && yarn install"; fi

  # Check if Tmux is installed, then start a new Tmux session
  if command -v tmux &>/dev/null; then
    if tmux has-session -t "$session_name" 2>/dev/null; then
      echo "cd '$dir' && tmux attach -t '$session_name'"
    else
      echo "cd '$dir' && $deps && tmux new-session -s '$session_name'"
    fi
  else
    echo "cd '$dir' && $deps"
  fi
}

open_in_windows_terminal() {
  local dir="$1"
  local session_name="$2"
  local tab_cmd="$3"
  local win_dir
  win_dir="$(wslpath -w "$dir")"

  if command -v tmux &>/dev/null; then
    wt.exe -w 0 new-tab --profile "$WSL_DISTRO_NAME" --title "$session_name" -d "$win_dir" -- bash -ic "$tab_cmd"
  else
    wt.exe -w 0 new-tab --profile "$WSL_DISTRO_NAME" --title "$session_name" -d "$win_dir"
  fi
}

open_in_iterm() {
  local session_name="$1"
  local tab_cmd="$2"

  osascript <<EOF || echo "Could not open iTerm2 tab."
tell application "iTerm2"
  tell current window
    create tab with default profile
    tell current session
      set name to "$session_name"
      write text "$tab_cmd"
    end tell
  end tell
end tell
EOF
}

open_in_apple_terminal() {
  local session_name="$1"
  local tab_cmd="$2"

  # Terminal.app doesn't support "make new tab" so we simulate Cmd+T.
  # A delay is needed because the keystroke is async; without it,
  # "do script" runs in the previous tab instead of the new one.
  osascript <<EOF || echo "Could not open Terminal.app tab."
tell application "Terminal"
  activate
  tell application "System Events" to keystroke "t" using command down
  delay 1
  do script "$tab_cmd" in selected tab of front window
  set custom title of selected tab of front window to "$session_name"
  set title displays custom title of selected tab of front window to true
end tell
EOF
}

open_worktree() {
  local dir="$1"
  local session_name="$2"

  # Sanitize for tmux (no dots or colons)
  session_name="${session_name//[:.]/-}"

  local tab_cmd
  tab_cmd="$(build_tab_cmd "$dir" "$session_name")"

  # WSL + Windows Terminal
  if [[ -n "${WSL_DISTRO_NAME:-}" ]] && command -v wt.exe &>/dev/null; then
    open_in_windows_terminal "$dir" "$session_name" "$tab_cmd"
    return
  fi

  # iTerm2
  if [[ "${TERM_PROGRAM:-}" == "iTerm.app" || "${__CFBundleIdentifier:-}" == "com.googlecode.iterm2" ]]; then
    open_in_iterm "$session_name" "$tab_cmd"
    return
  fi

  # macOS Terminal.app
  if [[ "${TERM_PROGRAM:-}" == "Apple_Terminal" || "${__CFBundleIdentifier:-}" == "com.apple.Terminal" ]]; then
    open_in_apple_terminal "$session_name" "$tab_cmd"
    return
  fi

  echo "Unsupported terminal: unable to open a new tab." >&2
  exit 1
}

pick_name() {
  for n in "${NAME_POOL[@]}"; do
    if [[ ! -d "../${DIRECTORY}-${n}" ]]; then
      echo "$n"
      return
    fi
  done
  echo "Error: all worktree names are in use" >&2
  exit 1
}

usage() {
  echo "Usage: gw add <branch>"
  echo "       gw remove [name]"
  exit 1
}

case "$1" in
add)
  [[ $# -lt 2 ]] && usage
  name="$(pick_name)"
  add_worktree "$2" "../${DIRECTORY}-${name}"
  copy_files
  open_worktree "$(pwd)" "$name"
  ;;
remove)
  if [[ -n "${2:-}" ]]; then
    remove_worktree "../${DIRECTORY}-${2}" "${@:3}"
  else
    remove_worktree "$(pwd)"
  fi
  if [[ -n "${TMUX:-}" ]]; then
    tmux kill-session
  fi
  ;;
*)
  usage
  ;;
esac
