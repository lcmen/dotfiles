{
  "agent": {
    "default_profile": "ask",
    "default_width": 500,
    "flexible": false,
    "single_file_review": true,
    "thinking_display": "always_collapsed",
    "use_modifier_to_send": true,
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
      "env": {
        "CLAUDE_CODE_EXECUTABLE": "/Users/lucas/.local/bin/claude",
      },
    },
    "codex-acp": {
      "type": "registry",
    },
  },
  "cli_default_open_behavior": "new_window",
  "collaboration_panel": {
    "button": false,
  },
  "debugger": {
    "button": false,
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "format_on_save": "on",
  "git_panel": {
    "tree_view": true,
  },
  "icon_theme": "Material Icon Theme",
  "languages": {
    "Ruby": {
      "language_servers": ["ruby-lsp", "!solargraph"],
    },
  },
  "outline_panel": {
    "button": false,
  },
  "preview_tabs": {
    "enabled": false,
  },
  "project_panel": {
    "auto_fold_dirs": true,
    "auto_reveal_entries": true,
    "hide_root": true,
    "indent_guides": {
      "show": "never",
    },
  },
  "relative_line_numbers": "enabled",
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "font_family": "FiraCode Nerd Font Mono",
  },
  "title_bar": {
    "show_sign_in": false,
  },
  "theme": {
    "dark": "GitHub Dark",
    "light": "GitHub Light",
    "mode": "system",
  },
  "vim_mode": true,
}
