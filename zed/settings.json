{
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
  },
  "agent": {
    "notify_when_agent_waiting": "all_screens",
    "default_profile": "ask",
    "default_width": 500,
    "flexible": false,
    "single_file_review": true,
    "use_modifier_to_send": true,
  },
  "cli_default_open_behavior": "new_window",
  "collaboration_panel": {
    "button": false,
  },
  "debugger": {
    "button": false,
  },
  "diff_view_style": "unified",
  "edit_predictions": {
    "provider": "none",
  },
  "format_on_save": "on",
  "git_panel": {
    "default_width": 280,
    "tree_view": true,
  },
  "icon_theme": "Material Icon Theme",
  "languages": {
    "HTML": {
      "soft_wrap": "bounded",
    },
    "Ruby": {
      "language_servers": ["ruby-lsp", "!solargraph"],
    },
  },
  "outline_panel": {
    "button": false,
  },
  "preferred_line_length": 120,
  "prettier": {
    "allowed": true,
  },
  "preview_tabs": {
    "enabled": false,
  },
  "project_panel": {
    "auto_fold_dirs": true,
    "auto_reveal_entries": true,
    "default_width": 280,
    "hide_root": true,
    "indent_guides": {
      "show": "never",
    },
  },
  "relative_line_numbers": "enabled",
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "tab_size": 2,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "font_family": "FiraCode Nerd Font Mono",
  },
  "title_bar": {
    "show_sign_in": false,
  },
  "theme": {
    "dark": "GitHub Dark",
    "light": "GitHub Light",
    "mode": "system",
  },
  "when_closing_with_no_tabs": "keep_window_open",
  "vim_mode": true,
}
