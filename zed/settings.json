{
  "agent": {
    "default_width": 400,
    "flexible": false,
    "single_file_review": true,
    "thinking_display": "always_collapsed",
    "use_modifier_to_send": true,
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
  },
  "collaboration_panel": {
    "button": false,
  },
  "debugger": {
    "button": false,
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "format_on_save": "on",
  "icon_theme": "Material Icon Theme",
  "outline_panel": {
    "button": false,
  },
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_file_finder": false,
    "enable_keep_preview_on_code_navigation": false,
  },
  "project_panel": {
    "auto_fold_dirs": true,
    "auto_reveal_entries": true,
    "hide_root": true,
    "indent_guides": {
      "show": "never",
    },
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "font_family": "FiraCode Nerd Font Mono",
  },
  "title_bar": {
    "show_sign_in": false,
  },
  "theme": {
    "dark": "GitHub Dark",
    "light": "GitHub Light",
    "mode": "system",
  },
  "vim_mode": true,
}
