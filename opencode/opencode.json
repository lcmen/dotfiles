{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "plan": {
      "permission": {
        "edit": "deny",
        "write": "deny"
      }
    }
  },
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "find *": "allow",
      "head *": "allow",
      "ls*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow"
    },
    "edit": "ask",
    "explore": "allow",
    "glob": "allow",
    "grep": "allow",
    "read": "allow",
    "skill": "allow",
    "todowrite": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": true
    }
  }
}
