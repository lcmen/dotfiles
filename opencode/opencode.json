{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "permission": {
        "read": "allow",
        "grep": "allow",
      }
    },
    "plan": {
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "write": "deny"
      }
    }
  },
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "ls *": "allow"
    },
    "edit": "ask"
  }
}
