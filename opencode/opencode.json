{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "plan": {
      "permission": {
        "edit": "deny",
        "write": "deny"
      }
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "find *": "allow",
      "git *": "ask",
      "git diff *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "read *": "allow",
      "wc *": "allow"
    },
    "edit": "ask"
  },
  "mcp": {
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  }
}
